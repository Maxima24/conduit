{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Conduit NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2023",
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,
    "outDir": "dist",
    "baseUrl": ".",
    "incremental": true
  }
}
